{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Information",
      "SourceFlow": "Trace"
    }
  },
  "CloudIntegrationTests": {
    "UseEmulators": true,
    "RunPerformanceTests": false,
    "TestTimeout": "00:10:00",
    "Aws": {
      "UseLocalStack": true,
      "RunPerformanceTests": false
    },
    "Azure": {
      "UseAzurite": true,
      "RunPerformanceTests": false
    },
    "Performance": {
      "ThroughputTest": {
        "MessageCount": 100,
        "ConcurrentSenders": 2,
        "Duration": "00:00:30"
      },
      "LatencyTest": {
        "MessageCount": 50,
        "WarmupMessages": 5
      },
      "ScalabilityTest": {
        "MaxConcurrency": 10,
        "MessagesPerStep": 100
      }
    }
  }
}